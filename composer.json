{
    "name": "verkdev/stripebaldeui",
    "description": "Ready to use Stripe payment gateway with Blade UI for Laravel.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Verkdev",
            "email": "worksdev.com@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2 || ^8.3",
        "laravel/framework": "^11.0 || ^12.0 || ^13.0",
        "stripe/stripe-php": "^13.0 || ^14.0 || ^15.0 || ^16.0 || ^17.0"
    },
    "autoload": {
        "psr-4": {
            "Verkdev\\StripeBladeUi\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Verkdev\\StripeBladeUi\\StripeBladeUiServiceProvider"
            ],
            "aliases": {},
            "dont-discover": []
        }
    }
}
